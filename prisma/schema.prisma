// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String?  // Hashed password, null means they use default
  name             String
  role             String   @default("EMPLOYEE")
  position         String?
  department       String?
  contactNumber    String?
  emergencyContact String?
  address          String?
  icId             String?  // Independent Contractor ID
  
  // Self-relation for Supervisors
  managerId        String?
  manager          User?    @relation("UserToManager", fields: [managerId], references: [id])
  teamMembers      User[]   @relation("UserToManager")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  timeLogs         TimeLog[]
  leaveBalances    LeaveBalance[]
  leaveRequests    LeaveRequest[]

  schedules        Schedule[]     // Assigned weekly schedules
  specialSchedules SpecialSchedule[] // Overrides for specific dates
  assignedHolidays AssignedHoliday[] // Holidays specific to this user
  overtimeRequests OvertimeRequest[] // Overtime filed by user
  overtimeApprovals OvertimeRequest[] @relation("ManagerToOvertime") // Overtime approved by user as manager
  manualTimeRequests ManualTimeRequest[] // Manual time entries filed by user
  manualTimeApprovals ManualTimeRequest[] @relation("ManagerToManualTime") // Manual time entries approved by user as manager
  auditLogs        AuditLog[]     // Actions performed by user
  notifications    Notification[]
  announcements    Announcement[]
  pages            Page[]
}

model TimeLog {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  clockIn   DateTime  @default(now())
  clockOut  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, clockIn])
  @@index([clockIn])
}

model LeaveBalance {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  leaveType String   // e.g., VACATION, SICK
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, leaveType])
}

model LeaveRequest {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  leaveType     String   // e.g., VACATION, SICK
  startDate     DateTime
  endDate       DateTime
  reason        String?
  attachmentUrl String?  // Optional in DB to prevent migration issues, but required in UI
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, status])
}


model Holiday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  type        String   @default("REGULAR") // REGULAR, SPECIAL_NON_WORKING, etc
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model Schedule {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  dayOfWeek Int      // 0 (Sun) to 6 (Sat)
  startTime String   // e.g., "09:00"
  endTime   String   // e.g., "18:00"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, dayOfWeek])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // e.g., LOGIN, PFFD_APPROVED, CLOCK_IN
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  details   String?  // JSON string or description
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action])
}

model AssignedHoliday {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, date])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  href      String?
  type      String    @default("INFO")
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([createdAt])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String?
  icon      String   @default("FileText")
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Page?    @relation("PageOrganization", fields: [parentId], references: [id], onDelete: Cascade)
  children  Page[]   @relation("PageOrganization")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([parentId])
}

model SpecialSchedule {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime // The specific date this schedule applies to
  startTime String   // e.g., "09:00"
  endTime   String   // e.g., "18:00"
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model OvertimeRequest {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  startDate     DateTime
  endDate       DateTime
  startTime     String   // e.g., "18:00"
  endTime       String   // e.g., "20:00"
  reason        String
  attachmentUrl String?  // URL to the uploaded file/proof
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  managerId     String?  // The manager who approved/rejected
  manager       User?    @relation("ManagerToOvertime", fields: [managerId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, status])
}

model ManualTimeRequest {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  logType       String   // e.g., "CLOCK_IN" or "CLOCK_OUT"
  logDateTime   DateTime
  reason        String
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  managerId     String?  // The manager who approved/rejected
  manager       User?    @relation("ManagerToManualTime", fields: [managerId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, status])
}
